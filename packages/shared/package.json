{
  "name": "@getbeyond/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared types + contracts (adapter interfaces, draft schemas). MIT — embedders can build closed-source adapters against this surface.",
  "license": "MIT",
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./connector-contracts": {
      "types": "./dist/connector-contracts.d.ts",
      "require": "./dist/connector-contracts.js",
      "import": "./dist/connector-contracts.js",
      "default": "./dist/connector-contracts.js"
    },
    "./researcher-contracts": {
      "types": "./dist/researcher-contracts.d.ts",
      "require": "./dist/researcher-contracts.js",
      "import": "./dist/researcher-contracts.js",
      "default": "./dist/researcher-contracts.js"
    },
    "./sdr-drafter-contracts": {
      "types": "./dist/sdr-drafter-contracts.d.ts",
      "require": "./dist/sdr-drafter-contracts.js",
      "import": "./dist/sdr-drafter-contracts.js",
      "default": "./dist/sdr-drafter-contracts.js"
    },
    "./campaign-contracts": {
      "types": "./dist/campaign-contracts.d.ts",
      "require": "./dist/campaign-contracts.js",
      "import": "./dist/campaign-contracts.js",
      "default": "./dist/campaign-contracts.js"
    },
    "./llm-settings-contracts": {
      "types": "./dist/llm-settings-contracts.d.ts",
      "require": "./dist/llm-settings-contracts.js",
      "import": "./dist/llm-settings-contracts.js",
      "default": "./dist/llm-settings-contracts.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
