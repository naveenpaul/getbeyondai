// getbeyond — canonical Prisma schema.
//
// Generated from the eng-reviewed plan at ../../../gtm_teammates_plan.md.
// Pass-1 + pass-2 decisions referenced inline (e.g. "Issue 4A", "D2", "codex T6").
//
// Architecture invariants:
//   1. Multi-user from day 1 — every tenant-scoped table has `orgId`.
//   2. Citations first-class — Claim has citationId OR abstained=true (enforced in runtime).
//   3. Audit log is primary — AgentRun + ToolCall + ModelCall + Citation are not afterthoughts.
//   4. Connectors quarantined — Contact unifies; ContactSource preserves per-vendor data.
//   5. DraftAction is an outbox — strict ordering via dependsOnId, idempotency-keyed CRM writes.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext]
}

// ============================================================================
// Tenancy — Organization + User
// ============================================================================

enum Plan {
  self_host
  solo
  team
  growth
  enterprise
}

enum UserRole {
  owner
  admin
  member
}

model Organization {
  id        String   @id @default(cuid())
  name      String?
  plan      Plan     @default(self_host)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships       OrgMembership[]
  activeForUsers    User[]             @relation("UserActiveOrg")
  invites           Invite[]
  companyBrain      CompanyBrain?
  agentRuns         AgentRun[]
  drafts            Draft[]
  contacts          Contact[]
  contactLists      ContactList[]
  connectorAccounts ConnectorAccount[]
  syncRuns          SyncRun[]
  llmCredentials    OrgLlmCredential[]
  teammateConfigs   OrgTeammateConfig[]
  campaigns         Campaign[]

  @@map("organizations")
}

// One user can belong to many organizations. The (userId, orgId) pair carries
// the role for that org — replaces the old User.role singleton.
model OrgMembership {
  id        String   @id @default(cuid())
  userId    String
  orgId     String
  role      UserRole @default(member)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([orgId])
  @@map("org_memberships")
}

model User {
  id            String   @id @default(cuid())
  // The org the user is currently acting in. AuthGuard verifies a matching
  // OrgMembership exists before trusting this on each request. Multi-org users
  // flip this via POST /me/active-org.
  activeOrgId   String
  email         String   @db.Citext
  emailVerified Boolean  @default(false)
  name          String?
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  activeOrg       Organization    @relation("UserActiveOrg", fields: [activeOrgId], references: [id], onDelete: Cascade)
  memberships     OrgMembership[]
  invitesSent     Invite[]        @relation("InvitedBy")
  invitesAccepted Invite[]        @relation("InviteAcceptedBy")
  voices          Voice[]
  sessions        Session[]
  accounts        Account[]

  @@unique([email]) // better-auth's prismaAdapter looks up users by email globally
  @@map("users")
}

// Pending or accepted invitation to join an org. Tokens are 32-byte random
// base64url. We allow at most one open invite per (orgId, email) — re-inviting
// the same address either renews the existing row or replaces it.
model Invite {
  id               String    @id @default(cuid())
  orgId            String
  email            String    @db.Citext
  role             UserRole  @default(member)
  token            String    @unique
  expiresAt        DateTime
  invitedByUserId  String
  acceptedAt       DateTime?
  acceptedByUserId String?
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invitedBy  User         @relation("InvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  acceptedBy User?        @relation("InviteAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@unique([orgId, email]) // only one outstanding invite per address per org
  @@index([email]) // signup hook looks up pending invites by email
  @@index([orgId])
  @@map("invites")
}

// ============================================================================
// Auth — better-auth tables (T6.1)
//
// Schema shapes match what better-auth's prismaAdapter expects. See
// https://www.better-auth.com/docs/concepts/database for the canonical
// field list. Our User row carries activeOrgId on top of better-auth's
// minimum surface — set atomically via the user.create.before hook + an
// OrgMembership row written by user.create.after in
// `apps/api/src/modules/auth/auth.config.ts` so activeOrgId can stay NOT NULL.
// ============================================================================

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt]) // reaper sweep
  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String // vendor's id (email for magic-link, OAuth subject for Google, etc.)
  providerId            String // 'magic-link' | 'google' | 'github' | …
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?   @db.Text // bcrypted; null for non-credential providers
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String // typically email
  value      String   @db.Text // the token / magic-link payload
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@index([expiresAt]) // reaper sweep
  @@map("verifications")
}

// ============================================================================
// Company Brain + Voice (per-channel — pass-1 Issue 4B-2)
// ============================================================================

model CompanyBrain {
  id          String   @id @default(cuid())
  orgId       String   @unique
  icp         Json     @default("{}")
  offer       Json     @default("{}")
  productInfo Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  voices Voice[]

  @@map("company_brains")
}

enum VoiceChannel {
  email
  linkedin_dm
  linkedin_post
  twitter_post
}

model Voice {
  id        String       @id @default(cuid())
  brainId   String
  userId    String
  channel   VoiceChannel
  signature Json         @default("{}") // sentence length, openings, banned phrases
  bestPosts Json         @default("[]") // few-shot corpus (array of {channel, text, score})
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  brain CompanyBrain @relation(fields: [brainId], references: [id], onDelete: Cascade)
  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([brainId, userId, channel])
  @@map("voices")
}

// ============================================================================
// Audit log — primary tables (eng-review pass-1: AgentRun + ToolCall + ModelCall + Citation)
// ============================================================================

enum RunStatus {
  running
  completed
  failed
  abstained
}

model AgentRun {
  id            String    @id @default(cuid())
  orgId         String
  teammate      String // 'researcher' | 'sdr-drafter' | 'content-drafter' | ...
  triggeredBy   String // userId or 'system'
  status        RunStatus @default(running)
  reason        String? // e.g. 'exceeded_maxToolCalls' (pass-1 Issue 6A)
  inputContext  Json      @default("{}")
  outputDraftId String?
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  lastBeatAt    DateTime  @default(now()) // pass-1 Issue 2A — heartbeat for stale-run reaper
  costCents     Int       @default(0)

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  toolCalls  ToolCall[]
  modelCalls ModelCall[]
  citations  Citation[]
  drafts     Draft[]

  @@index([orgId, startedAt])
  @@index([status, lastBeatAt]) // reaper query
  @@map("agent_runs")
}

model ModelCall {
  id           String   @id @default(cuid())
  runId        String
  // Which LLM provider served this call. Nullable: pre-abstraction rows (and
  // rows written before P5 wires call-model.ts to populate it) have no
  // provider recorded. Backfilling a NOT NULL column would require a default
  // for existing rows, which would silently mislabel historical Anthropic-only
  // calls — leaving it null is the honest "unknown" state. (Populated in P5.)
  provider     Provider?
  modelName    String
  inputTokens  Int
  outputTokens Int
  costCents    Int      @default(0)
  at           DateTime @default(now())

  run       AgentRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  toolCalls ToolCall[]

  @@index([runId])
  @@map("model_calls")
}

model ToolCall {
  id          String   @id @default(cuid())
  runId       String
  modelCallId String? // pass-1 Issue 6B — backref to API call that decided to invoke this tool
  toolSeq     Int // pass-1 Issue 2A — idempotent inserts under (runId, toolSeq)
  toolName    String
  args        Json
  result      Json // when result >50KB inline; otherwise: { type: 's3', key, preview: 'first 500 chars' } (Issue 2D)
  durationMs  Int
  costCents   Int      @default(0)
  at          DateTime @default(now())

  run       AgentRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  modelCall ModelCall? @relation(fields: [modelCallId], references: [id], onDelete: SetNull)

  @@unique([runId, toolSeq])
  @@index([runId])
  @@map("tool_calls")
}

model Citation {
  id          String   @id @default(cuid())
  runId       String
  url         String
  title       String?
  excerpt     String?  @db.Text
  retrievedAt DateTime @default(now())

  run    AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  claims Claim[]

  @@index([runId])
  @@index([url])
  @@map("citations")
}

// ============================================================================
// Drafts + Claims + TeammateConfig
// ============================================================================

enum DraftType {
  email
  linkedin_dm
  linkedin_post
  twitter_post
  research_brief
}

enum DraftStatus {
  pending
  approved
  rejected
  edited
  sent
  partial // pass-2 D5 — some DraftActions succeeded, some dead-lettered
  failed
}

model Draft {
  id           String      @id @default(cuid())
  orgId        String
  teammate     String
  runId        String?
  type         DraftType
  recipient    Json? // { contactId, email, name, ... } — soft FK to Contact via contactId
  content      Json // { subject, body } | { content } | { headline, body } etc.
  status       DraftStatus @default(pending)
  approvedBy   String? // userId
  approvedAt   DateTime?
  editLog      Json        @default("[]") // every diff → few-shot for next run
  scheduledFor DateTime?
  postedAt     DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  org     Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  run     AgentRun?     @relation(fields: [runId], references: [id], onDelete: SetNull)
  claims  Claim[]
  actions DraftAction[]

  @@index([orgId, status])
  @@index([orgId, createdAt])
  @@map("drafts")
}

model Claim {
  id         String   @id @default(cuid())
  draftId    String
  text       String   @db.Text
  citationId String? // null only when abstained=true; runtime drops uncited claims at synthesis
  confidence Float?
  abstained  Boolean  @default(false)
  createdAt  DateTime @default(now())

  draft    Draft     @relation(fields: [draftId], references: [id], onDelete: Cascade)
  citation Citation? @relation(fields: [citationId], references: [id], onDelete: SetNull)

  @@index([draftId])
  @@map("claims")
}

enum ApprovalPolicy {
  draft_only
  auto_above_confidence
  autonomous
}

model TeammateConfig {
  teammate           String         @id // 'researcher' | 'sdr-drafter' | 'content-drafter'
  toolAllowlist      String[]
  approvalPolicy     ApprovalPolicy @default(draft_only)
  modelPrimary       String         @default("claude-sonnet-4-6")
  modelFast          String         @default("claude-haiku-4-5-20251001")
  defaultBudgetCents Int            @default(100)
  maxToolCalls       Int            @default(25) // pass-1 Issue 6A
  maxWallSecs        Int            @default(180)
  maxParallelCalls   Int            @default(3)
  updatedAt          DateTime       @updatedAt

  @@map("teammate_configs")
}

// ============================================================================
// LLM provider abstraction (P3) — org-scoped BYO credentials + routing config.
// Credential per (org, provider); routing per (org, teammate). See
// docs/plans/llm-provider-abstraction.md.
// ============================================================================

enum Provider {
  anthropic
  openai
}

// Org-scoped bring-your-own LLM key. Mirrors ConnectorAccount: a sealed secret
// + version, unique per (org, provider). The sealed `apiKey` decrypts only
// inside the provider adapter boundary via credential-encryption.ts.
model OrgLlmCredential {
  id         String   @id @default(cuid())
  orgId      String
  provider   Provider
  apiKey     Bytes // sealed via credential-encryption.ts; decrypts only in adapter
  keyVersion Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, provider])
  @@map("org_llm_credentials")
}

// Org-scoped routing for a teammate: which provider + which models. Supersedes
// the routing role of the (global) TeammateConfig table.
model OrgTeammateConfig {
  id           String   @id @default(cuid())
  orgId        String
  teammate     String
  provider     Provider @default(anthropic)
  modelPrimary String   @default("claude-sonnet-4-6")
  modelFast    String   @default("claude-haiku-4-5-20251001")
  updatedAt    DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, teammate])
  @@map("org_teammate_configs")
}

// ============================================================================
// Campaigns — the maintained "activity" behind the chat workspace. A campaign
// is a lookalike-sourcing run: derive an ICP from a wins list, source a
// candidate pool, qualify + rank via the Researcher. See
// docs/product-workflow-spec.md. The orchestrator + run linkage land in a
// follow-up; this is the persisted entity + status.
// ============================================================================

enum CampaignStatus {
  draft // created, not yet run
  running // orchestrator executing
  completed
  failed
}

model Campaign {
  id     String         @id @default(cuid())
  orgId  String
  title  String
  goal   String // the natural-language intent the user typed in the chat
  status CampaignStatus @default(draft)
  // Soft reference (like ContactList.source) to the ContactList of closed-won
  // accounts the ICP is derived from. Nullable until a wins list is attached.
  winsListId String?
  createdBy  String // userId
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org        Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  candidates CampaignCandidate[]

  @@index([orgId, status])
  @@map("campaigns")
}

// A sourced company qualified + scored against the campaign ICP. The cited
// firmographic signals live on the linked Researcher Draft (cite-or-abstain
// enforced by the runtime); fitScore + rationale are the orchestrator's ranking.
model CampaignCandidate {
  id          String   @id @default(cuid())
  campaignId  String
  name        String
  domain      String?
  linkedinUrl String?
  fitScore    Float
  rationale   String
  draftId     String? // the Researcher's cited brief for this candidate
  createdAt   DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("campaign_candidates")
}

// ============================================================================
// Connector layer — pass-2 canonical (D2 / D3 / D4 / D6 / D9 + codex T2/T3/T4/T5)
// ============================================================================

enum ConnectorKind {
  hubspot
  salesforce
  apollo
  zoominfo
  csv
}

enum AuthMode {
  oauth
  byo_key
  upload
}

enum ConnectorStatus {
  active
  expired
  revoked
  error
  circuit_broken
}

model ConnectorAccount {
  id                 String          @id @default(cuid())
  orgId              String
  kind               ConnectorKind
  authMode           AuthMode
  credentials        Bytes // libsodium-sealed; decrypts only inside the adapter boundary
  credentialsVersion Int             @default(1) // CAS on refresh-token rotation (D4 + codex T5)
  scopes             String[]        @default([])
  status             ConnectorStatus @default(active)
  dailyBudgetCents   Int? // per-org cost cap for BYO-key vendors (codex T8)
  lastSyncAt         DateTime?
  lastError          String?         @db.Text
  circuitOpenedAt    DateTime? // null unless status='circuit_broken'; reset after cooldown
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  org            Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contactEmails  ContactEmail[]
  contactSources ContactSource[]
  syncRuns       SyncRun[]
  draftActions   DraftAction[]

  @@unique([orgId, kind])
  @@map("connector_accounts")
}

// Canonical Contact (pass-2 D6) — normalized fields only.
// Per-source data lives in ContactSource. Multiple emails via ContactEmail (codex T2).
model Contact {
  id              String    @id @default(cuid())
  orgId           String
  firstName       String?
  lastName        String?
  title           String?
  company         String?
  linkedinUrl     String?
  normalizedEmail String?   @db.Citext // primary identity (D2). Lowercase, plus-stripped, subdomain-preserved. Null when no email.
  fieldProvenance Json      @default("{}") // per-field: { title: {source, updatedAt}, ... } (D3 per-field, codex T4)
  lastEditedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  org     Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  emails  ContactEmail[]
  sources ContactSource[]
  lists   ContactListMember[]

  @@unique([orgId, normalizedEmail]) // primary identity constraint; NULL allowed, fallback to linkedinUrl
  @@index([orgId, linkedinUrl]) // identity fallback when email missing
  @@map("contacts")
}

model ContactEmail {
  id              String   @id @default(cuid())
  contactId       String
  normalizedEmail String   @db.Citext
  rawEmail        String
  isPrimary       Boolean  @default(false)
  sourceAccountId String? // ConnectorAccount that surfaced this email; null for manual entries
  createdAt       DateTime @default(now())

  contact       Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  sourceAccount ConnectorAccount? @relation(fields: [sourceAccountId], references: [id], onDelete: SetNull)

  @@unique([contactId, normalizedEmail])
  @@index([normalizedEmail])
  @@map("contact_emails")
}

model ContactSource {
  id                String   @id @default(cuid())
  contactId         String
  sourceAccountId   String
  externalId        String
  externalUrl       String?
  rawPayload        Json // when ≤10KB inline; when >10KB: { type: 's3', key, sha256, preview } (D9 + codex T3)
  rawPayloadVersion Int      @default(1) // CAS for retry/reconciliation
  lastSyncedAt      DateTime @default(now())

  contact       Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  sourceAccount ConnectorAccount @relation(fields: [sourceAccountId], references: [id], onDelete: Cascade)

  @@unique([sourceAccountId, externalId])
  @@index([contactId])
  @@map("contact_sources")
}

model ContactList {
  id           String   @id @default(cuid())
  orgId        String
  source       String // 'hubspot:list:xyz' | 'apollo:search:abc' | 'csv:upload:def'
  name         String
  contactCount Int      @default(0)
  createdBy    String // userId
  createdAt    DateTime @default(now())

  org     Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members ContactListMember[]

  @@index([orgId])
  @@map("contact_lists")
}

model ContactListMember {
  listId    String
  contactId String
  addedAt   DateTime @default(now())

  list    ContactList @relation(fields: [listId], references: [id], onDelete: Cascade)
  contact Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([listId, contactId])
  @@index([contactId])
  @@map("contact_list_members")
}

enum SyncDirection {
  pull
  push
}

enum SyncStatus {
  running
  completed
  failed
}

model SyncRun {
  id                 String        @id @default(cuid())
  orgId              String
  connectorAccountId String
  direction          SyncDirection
  status             SyncStatus    @default(running)
  startedAt          DateTime      @default(now())
  completedAt        DateTime?
  recordsIn          Int           @default(0)
  recordsOut         Int           @default(0)
  errorCount         Int           @default(0)
  cursor             String? // resumable; persisted before each batch commit
  errors             Json          @default("[]")
  costCents          Int           @default(0) // vendor per-call costs

  org              Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  connectorAccount ConnectorAccount @relation(fields: [connectorAccountId], references: [id], onDelete: Cascade)

  @@index([orgId, startedAt])
  @@index([connectorAccountId, startedAt])
  @@map("sync_runs")
}

// Outbox-style write-back actions (pass-2 D5 + codex T6)
enum DraftActionKind {
  send_email
  post_linkedin
  post_twitter
  crm_log_activity
  crm_update_field
  archive
}

enum DraftActionStatus {
  pending
  running
  succeeded
  failed
  dead_lettered
}

model DraftAction {
  id                   String            @id @default(cuid())
  draftId              String
  kind                 DraftActionKind
  targetAccountId      String? // ConnectorAccount.id for CRM writes; null for email/post via integration
  payload              Json              @default("{}") // Zod-discriminated by kind (D7)
  payloadSchemaVersion Int               @default(1) // validated at enqueue AND dequeue (D7 + codex T7)
  dependsOnId          String? // self-FK — outbox state machine (D5)
  status               DraftActionStatus @default(pending)
  attempts             Int               @default(0) // 3 retries (1s/4s/16s) then dead_lettered
  idempotencyKey       String            @default(uuid()) // CRM-write idempotency
  responsePayload      Json?
  executedAt           DateTime?
  executedBy           String? // userId who approved
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  draft         Draft             @relation(fields: [draftId], references: [id], onDelete: Cascade)
  targetAccount ConnectorAccount? @relation(fields: [targetAccountId], references: [id], onDelete: SetNull)
  dependsOn     DraftAction?      @relation("DraftActionDependency", fields: [dependsOnId], references: [id], onDelete: SetNull)
  dependents    DraftAction[]     @relation("DraftActionDependency")

  @@index([status, dependsOnId]) // worker: ready-to-run = no dep OR dep.status='succeeded'
  @@index([draftId])
  @@index([idempotencyKey])
  @@map("draft_actions")
}

// ============================================================================
// OAuth — short-lived state token bridging /start → /callback (T3c.1)
// ============================================================================
//
// Why a table (not a cookie or in-memory map):
//   - Survives API process restart (real OAuth flows redirect off-site for
//     ~30-60s; in-memory state evaporates on deploy).
//   - Horizontal scaling — two API instances behind a load balancer share state.
//   - Auditable — replay attempts and expired uses are visible.
//
// TTL: 10 min. OAuthStateReaper sweeps expired rows on a 2-min cadence.
// One-shot: rows are deleted on consumption (callback success/fail both delete)
// so replay attacks land on "state not found", not stale-but-valid.

model OAuthState {
  id          String        @id @default(cuid())
  state       String // opaque random token the vendor echoes back on callback
  orgId       String
  kind        ConnectorKind // which adapter started this flow
  redirectUri String // the exact redirect_uri passed to the vendor; vendor will reject mismatch
  expiresAt   DateTime
  createdAt   DateTime      @default(now())

  @@unique([state]) // primary lookup on callback
  @@index([expiresAt]) // reaper sweep
  @@index([orgId, kind]) // stuck-flow surfacing
  @@map("oauth_states")
}
