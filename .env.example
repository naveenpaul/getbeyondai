# getbeyond — environment variables
# Copy to .env (gitignored) and fill in real values for local dev.

# --- Core ---
NODE_ENV=development
API_PORT=3000
WEB_PORT=3001

# --- CORS (comma-separated origins; leave blank to allow all in dev) ---
CORS_ORIGIN=http://localhost:3001

# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/getbeyond?schema=public"

# --- Auth ---
# Strong random strings (>=32 chars). Generate with: openssl rand -base64 48
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-in-production"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# better-auth session-cookie signing secret. Generate with: openssl rand -base64 48
# In dev this falls back to JWT_SECRET; production REQUIRES it set independently.
AUTH_SECRET="change-me-in-production"
# Optional override; defaults to http://localhost:$API_PORT
AUTH_BASE_URL=

# --- Encryption (libsodium master key for ConnectorAccount.credentials) ---
# Generate with: openssl rand -base64 32
CREDENTIAL_MASTER_KEY="change-me-in-production"

# --- LLM (BYO Anthropic; cloud users supply their own) ---
ANTHROPIC_API_KEY=

# --- Search ---
BRAVE_SEARCH_API_KEY=

# --- Content extraction (fetch_url) ---
# 'local' (default): zero-dependency regex strip — no extra service needed.
# 'jina':     clean markdown via r.jina.ai — no sidecar. Key-less by default;
#             JINA_API_KEY raises rate limits. Sends target URLs to a third
#             party unless JINA_READER_URL points at a self-hosted Reader.
# 'crawl4ai': browser-rendered markdown via the Crawl4AI sidecar (CRAWL4AI_URL
#             required). Heaviest (ships a Chromium container) but far cleaner
#             on JS-heavy / noisy pages.
CONTENT_PROVIDER=local
JINA_READER_URL=
JINA_API_KEY=
CRAWL4AI_URL=
CRAWL4AI_API_TOKEN=

# --- Storage (MinIO local; S3 in prod) ---
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="getbeyond-blobs"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"

# --- Email send (Resend default; users can BYO Smartlead/Instantly) ---
RESEND_API_KEY=

# --- OAuth (Google / LinkedIn / Microsoft) — only client IDs are public ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# --- Personality service (gb-personality microservice) ---
PERSONALITY_API_URL="http://localhost:8000"
PERSONALITY_API_KEY=

# --- Connector vendor SDKs (CRM OAuth client IDs; BYO API keys live in ConnectorAccount, not env) ---
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# --- Observability ---
POSTHOG_API_KEY=
SENTRY_DSN=
